# Configuración general de Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=cambia-esta-clave-en-produccion

# JWT
JWT_SECRET_KEY=cambia-esta-jwt-key-en-produccion

# Base de datos (SQLite por defecto para PoC)
DATABASE_URL=sqlite:///taller.db

# Directorio para subida de archivos
UPLOAD_FOLDER=uploads

# Nivel de logging
LOG_LEVEL=DEBUG
