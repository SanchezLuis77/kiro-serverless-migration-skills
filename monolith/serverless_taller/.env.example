# Base de datos — RDS PostgreSQL (NO SQLite)
DATABASE_URL=postgresql://usuario:password@host:5432/taller_db

# JWT
JWT_SECRET_KEY=cambia-esta-jwt-key-en-produccion
JWT_EXPIRES_HOURS=24

# Redis — ElastiCache (solo accesible desde VPC)
REDIS_URL=redis://taller-cache.xxxxx.cache.amazonaws.com:6379

# S3
S3_BUCKET_ADJUNTOS=taller-adjuntos-dev-123456789

# SES
SES_SENDER_EMAIL=noreply@taller.com

# DynamoDB — tabla de tokens revocados
TOKENS_TABLE=taller-tokens-revocados-dev

# AWS
AWS_REGION=us-east-1

# Logging
LOG_LEVEL=INFO
SQL_ECHO=false
